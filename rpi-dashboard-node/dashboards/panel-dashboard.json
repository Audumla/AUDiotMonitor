{
  "uid": "hwexp-panel-main",
  "title": "AUDiot Panel Display",
  "tags": ["hwexp", "panel"],
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "title": "GPU Core Temp",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "max by (host, device_id, logical_name, model) (hw_device_temperature_celsius{device_class=\"gpu\", sensor=\"core\"})",
          "format": "time_series",
          "legendFormat": "{{logical_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "CPU Package Temp",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "max by (host, logical_name) (hw_device_temperature_celsius{device_class=\"cpu\", sensor=\"package\"})",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "RAM Usage %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * (hw_device_memory_used_bytes{device_class=\"memory\"} / hw_device_memory_total_bytes{device_class=\"memory\"})",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 92 }
            ]
          }
        }
      }
    },
    {
      "title": "PSU Power",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "max by (device_id) (hw_device_power_watts{device_class=\"psu\", sensor=\"output\"})",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt"
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "query": "label_values(hw_host_uptime_seconds, host)",
        "refresh": 1
      }
    ]
  }
}
