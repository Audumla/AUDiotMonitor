{
  "uid": "audiot-triple-gpu-wide",
  "title": "AUDiot Triple GPU Wide",
  "tags": ["audiot", "custom", "wide", "gpu"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "2s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [

    {
      "id": 1,
      "type": "timeseries",
      "title": "GPU (AMD 7900XTX 1)",
      "gridPos": { "h": 5, "w": 3, "x": 0, "y": 0 },
      "targets": [{ "expr": "hw_device_utilization_percent{device_class=\"gpu\", component=\"compute\", device_id=\"pci-0000:03:00.0\"}", "legendFormat": "Compute" }],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden", "showLegend": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "none", "spanNulls": false, "showPoints": "never", "lineInterpolation": "smooth" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "orange", "value": 80 },
            { "color": "red", "value": 95 }
          ]}
        }
      }
    },

