    {
      "id": 4,
      "type": "timeseries",
      "title": "System CPU",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[30s])) * 100)", "legendFormat": "CPU %" }],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden", "showLegend": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "none", "spanNulls": false, "showPoints": "never", "lineInterpolation": "smooth" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "orange", "value": 75 },
            { "color": "red", "value": 90 }
          ]}
        }
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "System RAM",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "RAM %" }],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "hidden", "showLegend": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "none", "spanNulls": false, "showPoints": "never", "lineInterpolation": "smooth" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "orange", "value": 80 },
            { "color": "red", "value": 92 }
          ]}
        }
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "PSU Output",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "targets": [{ "expr": "sum(node_hwmon_power_watt)", "legendFormat": "Watts" }],
