{
  "uid": "audiot-triple-gpu-combined",
  "title": "AUDiot Triple GPU Combined",
  "tags": ["audiot", "custom", "wide", "gpu"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "2s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [

    {
      "id": 1,
      "type": "timeseries",
      "title": "GPU 1: 7900XTX (Compute + VRAM)",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        { 
          "expr": "hw_device_utilization_percent{device_class=\"gpu\", component=\"compute\", device_id=\"pci-0000:03:00.0\"}", 
          "legendFormat": "Compute %",
          "refId": "A"
        },
        { 
          "expr": "sum(hw_device_capacity_bytes{device_class=\"gpu\", component=\"memory\", device_id=\"pci-0000:03:00.0\", logical_name=~\".*_vram_used_bytes\"}) / sum(hw_device_capacity_bytes{device_class=\"gpu\", component=\"memory\", device_id=\"pci-0000:03:00.0\", logical_name=~\".*_vram_capacity_bytes\"}) * 100", 
          "legendFormat": "VRAM %",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Compute %" },
            "properties": [
              { "id": "color", "value": { "mode": "thresholds", "fixedColor": "green" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 60 },
                { "color": "orange", "value": 80 },
                { "color": "red", "value": 95 }
              ]}},
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "VRAM %" },
            "properties": [
              { "id": "color", "value": { "mode": "thresholds", "fixedColor": "blue" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "blue", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "orange", "value": 85 },
                { "color": "red", "value": 95 }
              ]}},
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.fillOpacity", "value": 5 }
            ]
          }
        ]
      }
    },

