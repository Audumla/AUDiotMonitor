{
  "uid": "audiot-panel-display",
  "title": "AUDiot Panel Display",
  "tags": ["audiot", "panel"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "query": "label_values(hw_host_uptime_seconds, host)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    { "id": 1, "type": "stat", "title": "CPU Usage",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }
        ]}, "color": { "mode": "thresholds" }
      }}
    },
    { "id": 2, "type": "stat", "title": "Memory Usage",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 92 }
        ]}, "color": { "mode": "thresholds" }
      }}
    },
    { "id": 3, "type": "stat", "title": "Root Disk",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\"}) * 100", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 }
        ]}, "color": { "mode": "thresholds" }
      }}
    },
    { "id": 4, "type": "stat", "title": "Load Average",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "targets": [
        { "expr": "node_load1",  "legendFormat": "1m" },
        { "expr": "node_load5",  "legendFormat": "5m" },
        { "expr": "node_load15", "legendFormat": "15m" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name", "orientation": "vertical" },
      "fieldConfig": { "defaults": { "unit": "short",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "orange", "value": 4 }, { "color": "red", "value": 8 }
        ]}, "color": { "mode": "thresholds" }
      }}
    },
    { "id": 5, "type": "stat", "title": "Uptime",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "time() - node_boot_time_seconds", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    { "id": 6, "type": "stat", "title": "hwexp Up",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "expr": "hw_host_uptime_seconds{host=~\"$host\"}", "legendFormat": "{{host}}" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short",
        "mappings": [{"type": "value", "options": {"1": {"text": "UP", "color": "green"}, "0": {"text": "DOWN", "color": "red"}}}],
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]}
      }}
    },
    { "id": 7, "type": "stat", "title": "Temperatures",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "targets": [{ "expr": "hw_device_temperature_celsius{host=~\"$host\"}", "legendFormat": "{{device_class}} {{logical_name}}", "instant": true }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "celsius",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "blue", "value": null }, { "color": "green", "value": 20 },
          { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }
        ]}, "color": { "mode": "thresholds" }
      }}
    },
    { "id": 8, "type": "stat", "title": "Fan Speeds",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "hw_device_fan_rpm{host=~\"$host\"}", "legendFormat": "{{device_class}} {{logical_name}}", "instant": true }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "rotrpm", "color": { "mode": "fixed", "fixedColor": "light-blue" } } }
    },
    { "id": 9, "type": "stat", "title": "Power",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "hw_device_power_watts{host=~\"$host\"}", "legendFormat": "{{device_class}} {{logical_name}}", "instant": true }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "watt", "color": { "mode": "fixed", "fixedColor": "yellow" } } }
    }
  ]
}
