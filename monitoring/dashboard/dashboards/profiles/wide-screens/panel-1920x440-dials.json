{
  "uid": "audiot-panel-1920x440-dials",
  "title": "AUDiot Panel [1920x440 Dials]",
  "tags": ["audiot", "panel", "wide", "dials"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "query": "label_values(hwexp_up, host)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "CPU Usage",
      "gridPos": { "h": 10, "w": 3, "x": 0, "y": 0 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "CPU" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "RAM Usage",
      "gridPos": { "h": 10, "w": 3, "x": 3, "y": 0 },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "RAM" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 92 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "GPU Processor Usage",
      "gridPos": { "h": 10, "w": 9, "x": 6, "y": 0 },
      "targets": [{ "expr": "hw_device_utilization_percent{host=~\"$host\", component=\"compute\", device_class=\"gpu\"}", "legendFormat": "{{logical_name}}" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "GPU Memory Usage",
      "gridPos": { "h": 10, "w": 9, "x": 15, "y": 0 },
      "targets": [{ "expr": "sum by (device_id) (hw_device_capacity_bytes{host=~\"$host\", device_class=\"gpu\", component=\"memory\", sensor=\"usage\"}) / sum by (device_id) (hw_device_capacity_bytes{host=~\"$host\", device_class=\"gpu\", component=\"memory\", sensor=\"capacity\"}) * 100", "legendFormat": "{{device_id}} VRAM" }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    }
  ]
}



