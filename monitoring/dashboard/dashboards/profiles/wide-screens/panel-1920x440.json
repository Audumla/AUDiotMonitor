      "title": "CPU",
      "description": "Aggregate CPU utilization",
      "gridPos": { "h": 9, "w": 3, "x": 18, "y": 0 },
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
