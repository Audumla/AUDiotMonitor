{
  "uid": "audiot-panel-1920x440",
  "title": "AUDiot GPU Panel [1920×440]",
  "tags": ["audiot", "gpu", "wide", "rpi"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },

  "panels": [

    {
      "id": 1,
      "type": "gauge",
      "title": "GPU 1 Compute",
      "description": "Navi 31 — pci-0000:03:00.0",
      "gridPos": { "h": 9, "w": 3, "x": 0, "y": 0 },
      "targets": [{
        "expr": "hw_device_utilization_percent{device_class=\"gpu\", component=\"compute\", device_id=\"pci-0000:03:00.0\"}",
        "legendFormat": "GPU 1"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },

