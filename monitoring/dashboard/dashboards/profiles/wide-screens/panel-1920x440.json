{
  "uid": "audiot-panel-1920x440",
  "title": "AUDiot Panel [1920x440]",
  "tags": ["audiot", "panel", "wide"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "query": "label_values(hwexp_up, host)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    { "id": 1, "type": "stat", "title": "CPU",
      "gridPos": { "h": 10, "w": 2, "x": 0, "y": 0 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 85 }]}
      }}
    },
    { "id": 2, "type": "stat", "title": "RAM",
      "gridPos": { "h": 10, "w": 2, "x": 2, "y": 0 },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 90 }]}
      }}
    },
    { "id": 3, "type": "stat", "title": "GPU",
      "gridPos": { "h": 10, "w": 2, "x": 4, "y": 0 },
      "targets": [{ "expr": "max(hw_device_utilization_percent{component=\"compute\"})", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 90 }]}
      }}
    },
    { "id": 4, "type": "stat", "title": "VRAM",
      "gridPos": { "h": 10, "w": 2, "x": 6, "y": 0 },
      "targets": [{ "expr": "max(hw_device_utilization_percent{component=\"memory\"})", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 90 }]}
      }}
    },
    { "id": 5, "type": "stat", "title": "Net RX",
      "gridPos": { "h": 10, "w": 2, "x": 8, "y": 0 },
      "targets": [{ "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[2m]))", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "fixed", "fixedColor": "blue" } }}
    },
    { "id": 6, "type": "stat", "title": "Net TX",
      "gridPos": { "h": 10, "w": 2, "x": 10, "y": 0 },
      "targets": [{ "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[2m]))", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "fixed", "fixedColor": "yellow" } }}
    },
    { "id": 7, "type": "stat", "title": "CPU Temp",
      "gridPos": { "h": 10, "w": 2, "x": 12, "y": 0 },
      "targets": [{ "expr": "max(hw_device_temperature_celsius{device_class=\"cpu\"})", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "celsius",
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }]}
      }}
    },
    { "id": 8, "type": "stat", "title": "GPU Temp",
      "gridPos": { "h": 10, "w": 2, "x": 14, "y": 0 },
      "targets": [{ "expr": "max(hw_device_temperature_celsius{device_class=\"gpu\"})", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "celsius",
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 85 }]}
      }}
    },
    { "id": 9, "type": "stat", "title": "Disk /",
      "gridPos": { "h": 10, "w": 2, "x": 16, "y": 0 },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100,
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 90 }]}
      }}
    },
    { "id": 10, "type": "stat", "title": "Power",
      "gridPos": { "h": 10, "w": 2, "x": 18, "y": 0 },
      "targets": [{ "expr": "sum(hw_device_power_watts)", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "watt", "color": { "mode": "fixed", "fixedColor": "orange" } }}
    },
    { "id": 11, "type": "stat", "title": "Uptime",
      "gridPos": { "h": 10, "w": 2, "x": 20, "y": 0 },
      "targets": [{ "expr": "time() - node_boot_time_seconds", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "grey" } }}
    },
    { "id": 12, "type": "stat", "title": "Status",
      "gridPos": { "h": 10, "w": 2, "x": 22, "y": 0 },
      "targets": [{ "expr": "hwexp_up", "legendFormat": "" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short",
        "mappings": [{"type": "value", "options": {"1": {"text": "OK", "color": "green"}, "0": {"text": "ERR", "color": "red"}}}],
        "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]}
      }}
    }
  ]
}
