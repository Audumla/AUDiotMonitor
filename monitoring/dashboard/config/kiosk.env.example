# AUDiot kiosk configuration
#
# Copy to:
#   ./config/kiosk.env
# Then edit the values you want to override.

# Grafana base URL used by kiosk.sh
GRAFANA_URL=http://localhost:3000

# Auto-refresh interval for the chosen dashboard
KIOSK_REFRESH=30s

# Force one dashboard UID for all screens. Leave blank to use profile defaults.
KIOSK_DASHBOARD=

# Default dashboard UID when no screen-class-specific override is set.
KIOSK_DASHBOARD_DEFAULT=audiot-system-overview

# Optional per-screen-class overrides.
KIOSK_DASHBOARD_ULTRAWIDE=
KIOSK_DASHBOARD_PORTRAIT=audiot-panel-portrait
KIOSK_DASHBOARD_1080P=audiot-panel-1080p
KIOSK_DASHBOARD_LANDSCAPE=

# Comma-separated fallback UIDs checked in order if the chosen UID is missing.
KIOSK_DASHBOARD_FALLBACKS=audiot-panel-display,audiot-system-overview
