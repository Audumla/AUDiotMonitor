# AUDiot Kiosk Configuration
#
# Copy to ./config/kiosk.env and edit as needed.
# Changes take effect on the next kiosk restart.

# ── Grafana connection ────────────────────────────────────────────────────────

GRAFANA_URL=http://localhost:3000

# ── Dashboard selection ───────────────────────────────────────────────────────

# Auto-refresh interval for the dashboard (Grafana duration string: 1s, 5s, 30s, 1m …)
KIOSK_REFRESH=5s

# Force a single dashboard UID for all screens regardless of resolution.
# Leave blank to use automatic screen-class detection below.
KIOSK_DASHBOARD=

# Default dashboard when no screen-class override matches.
KIOSK_DASHBOARD_DEFAULT=audiot-system-overview

# Per-resolution overrides — set only the ones you need.
KIOSK_DASHBOARD_ULTRAWIDE=audiot-triple-gpu-wide
KIOSK_DASHBOARD_PORTRAIT=audiot-panel-portrait
KIOSK_DASHBOARD_1080P=audiot-panel-1080p
KIOSK_DASHBOARD_LANDSCAPE=audiot-system-overview

# Comma-separated fallback UIDs tried in order when the selected UID is missing.
KIOSK_DASHBOARD_FALLBACKS=audiot-panel-display,audiot-system-overview

# ── Screen power management (DPMS) ───────────────────────────────────────────
#
# Works on both Wayland (swayidle + wlopm) and X11 (xset).
#
# KIOSK_DPMS_STANDBY: seconds of inactivity before the screen dims / enters
#                     DPMS standby (most displays reduce backlight at this point).
# KIOSK_DPMS_OFF    : seconds of inactivity before the display fully powers off.
#
# Set KIOSK_IDLE_TIMEOUT=0 to disable power management and keep screen always on.

KIOSK_IDLE_TIMEOUT=600

KIOSK_DPMS_STANDBY=600    # 10 minutes → dim
KIOSK_DPMS_OFF=1800       # 30 minutes → display off
