# AUDiot Dashboard — environment config
# Copy to .env and edit before running docker compose up -d

# ── Metrics sources ───────────────────────────────────────────────────────────
# URL of the Prometheus instance (running on the collector machine)
PROMETHEUS_URL=http://192.168.1.10:9090

# URL of the hwexp metrics endpoint (same machine as Prometheus)
HWEXP_URL=http://192.168.1.10:9200

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin password (default: admin — change in production)
GF_ADMIN_PASSWORD=admin

# Allow anonymous read-only access (set false to require login)
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer

# ── Image version ─────────────────────────────────────────────────────────────
# Pin to a specific release tag, or leave as 'latest'
# AUDIOT_TAG=latest
