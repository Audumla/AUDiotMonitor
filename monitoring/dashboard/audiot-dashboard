#!/usr/bin/env bash
#
# AUDiot Dashboard Manager - A Single Script Solution
#
# This script is the single entry point for installing, updating, configuring,
# and operating the AUDiot dashboard stack on a host machine.
#
# Author: Gemini
# Version: 2.0.0

set -euo pipefail

# --- Configuration ---
# All paths and settings are defined here for clarity.
# If not explicitly set, try to detect if we are already in a dashboard directory.
DEFAULT_INSTALL_DIR="/opt/docker/dashboard"
if [[ -f "./docker-compose.yml" ]] && [[ "$(basename "$(pwd)")" == "dashboard" ]]; then
    DEFAULT_INSTALL_DIR="$(pwd)"
fi

INSTALL_DIR="${AUDIOT_INSTALL_DIR:-$DEFAULT_INSTALL_DIR}"
REPO_BASE_URL="https://raw.githubusercontent.com/Audumla/AUDiotMonitor/main"
DOCKER_COMPOSE_URL="$REPO_BASE_URL/monitoring/dashboard/docker-compose.yml"
SELF_URL="$REPO_BASE_URL/monitoring/dashboard/audiot-dashboard" # URL to this script itself

# --- Script Info ---
SCRIPT_PATH_ON_HOST="/usr/local/bin/audiot-dashboard"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$INSTALL_DIR/config/kiosk.env"
KIOSK_SCRIPT="$INSTALL_DIR/kiosk.sh"
SERVICE_FILE="$HOME/.config/systemd/user/audiot-kiosk.service"
AUTOSTART_DIR="$HOME/.config/autostart"

# --- Helper Functions ---
timestamp() { date '+%Y-%m-%d %H:%M:%S'; }
info() { echo "$(timestamp) [audiot] $*"; }
warn() { echo "$(timestamp) [audiot] WARNING: $*"; }
die() { echo "$(timestamp) [audiot] ERROR: $*" >&2; exit 1; }

# --- Core Logic Functions ---

# Fetches the latest version of a file from the repository.
fetch_from_repo() {
    local remote_path="$1"
    local local_path="$2"
    info "Downloading ${remote_path##*/}..."
    if ! curl -fsSL "$remote_path" -o "$local_path"; then
        die "Failed to download '$remote_path'. Please check your network connection."
    fi
}

# Creates the necessary directory structure for a host-owned layout.
create_layout() {
    info "Creating installation layout in $INSTALL_DIR..."
    sudo mkdir -p "$INSTALL_DIR/config/grafana/provisioning/datasources"
    sudo mkdir -p "$INSTALL_DIR/config/grafana/provisioning/dashboards"
    sudo mkdir -p "$INSTALL_DIR/dashboards/profiles/standard"
    sudo mkdir -p "$INSTALL_DIR/dashboards/profiles/wide-screens"
    sudo mkdir -p "$INSTALL_DIR/dashboards/profiles/mobile"
    sudo mkdir -p "$INSTALL_DIR/dashboards/profiles/debug"
    sudo mkdir -p "$INSTALL_DIR/dashboards/custom"
    sudo chown -R "$USER":"$USER" "$INSTALL_DIR"
    info "Layout created."
}

# Applies the UI patch to the running Grafana container
do_apply_patch() {
    info "Applying UI patch to Grafana container..."
    # Sleep briefly to ensure the container is ready to accept exec commands
    sleep 3
    docker compose -f "$INSTALL_DIR/docker-compose.yml" exec -u root grafana /bin/sh /opt/grafana-patch/post-start-patch.sh || warn "Failed to apply UI patch."
}

# Installs or updates the dashboard stack.
do_install_or_update() {
    local is_update=$1
    
    if [[ "$is_update" == "false" ]]; then
        create_layout
    fi

    # Fetch all necessary files
    fetch_from_repo "$DOCKER_COMPOSE_URL" "$INSTALL_DIR/docker-compose.yml"
    fetch_from_repo "$REPO_BASE_URL/monitoring/dashboard/kiosk.sh" "$KIOSK_SCRIPT"
    fetch_from_repo "$REPO_BASE_URL/monitoring/dashboard/config/grafana/grafana.ini" "$INSTALL_DIR/config/grafana/grafana.ini"
    fetch_from_repo "$REPO_BASE_URL/monitoring/dashboard/config/grafana/custom-grafana.css" "$INSTALL_DIR/config/grafana/custom-grafana.css"
    fetch_from_repo "$REPO_BASE_URL/monitoring/dashboard/config/grafana/post-start-patch.sh" "$INSTALL_DIR/config/grafana/post-start-patch.sh"
    fetch_from_repo "$REPO_BASE_URL/monitoring/dashboard/config/grafana/provisioning/datasources/prometheus.yaml" "$INSTALL_DIR/config/grafana/provisioning/datasources/prometheus.yaml"
    fetch_from_repo "$REPO_BASE_URL/monitoring/dashboard/config/grafana/provisioning/dashboards/dashboards.yaml" "$INSTALL_DIR/config/grafana/provisioning/dashboards/dashboards.yaml"
    
    # Create kiosk.env if it doesn't exist
    if [ ! -f "$CONFIG_FILE" ]; then
        fetch_from_repo "$REPO_BASE_URL/monitoring/dashboard/config/kiosk.env.example" "$CONFIG_FILE"
    fi
    
    # Fetch dashboards (example of fetching one, could be expanded)
    fetch_from_repo "$REPO_BASE_URL/monitoring/dashboard/dashboards/profiles/standard/system-overview.json" "$INSTALL_DIR/dashboards/profiles/standard/system-overview.json"

    chmod +x "$KIOSK_SCRIPT"
    
    info "Starting Docker services..."
    docker compose -f "$INSTALL_DIR/docker-compose.yml" up -d
    
    do_apply_patch

    info "Configuring kiosk autostart..."
    do_kiosk_install

    info "Install/Update complete."
}

# Sets the active dashboard in the kiosk config.
do_set_dashboard() {
    local uid="$1"
    info "Setting active dashboard to $uid..."
    if ! grep -q "^KIOSK_DASHBOARD=" "$CONFIG_FILE"; then
        echo "KIOSK_DASHBOARD=$uid" >> "$CONFIG_FILE"
    else
        sed -i "s|^KIOSK_DASHBOARD=.*|KIOSK_DASHBOARD=$uid|" "$CONFIG_FILE"
    fi
    info "Dashboard set. Restarting kiosk..."
    do_restart_kiosk
}

# Restarts the kiosk service or process.
do_restart_kiosk() {
    local TARGET_USER="$USER"
    local TARGET_HOME="$HOME"
    if [ "$EUID" -eq 0 ] && [ -n "${SUDO_USER:-}" ]; then
        TARGET_USER="$SUDO_USER"
        TARGET_HOME="$(eval echo ~$SUDO_USER)"
    fi

    if systemctl --user is-active audiot-kiosk.service >/dev/null 2>&1; then
        systemctl --user restart audiot-kiosk.service
        info "Kiosk service restarted."
    elif [ -f "$KIOSK_SCRIPT" ]; then
        pkill -f "kiosk.sh" || true
        pkill -f "chromium" || true
        sleep 1
        local KIOSK_LOG="/tmp/audiot-kiosk-${TARGET_USER}.log"
        rm -f "$KIOSK_LOG"
        DISPLAY=:0 XAUTHORITY="${TARGET_HOME}/.Xauthority" nohup "$KIOSK_SCRIPT" >"$KIOSK_LOG" 2>&1 &
        info "Kiosk process restarted. Logs: $KIOSK_LOG"
    else
        warn "Kiosk script not found. Cannot restart."
    fi
}

# Installs the kiosk as a systemd service or autostart file.
do_kiosk_install() {
    local TARGET_USER="$USER"
    local TARGET_HOME="$HOME"
    local TARGET_UID=$(id -u)

    # Detect if we are running under sudo and find the real user
    if [ "$EUID" -eq 0 ] && [ -n "${SUDO_USER:-}" ]; then
        TARGET_USER="$SUDO_USER"
        TARGET_HOME="$(eval echo ~$SUDO_USER)"
        TARGET_UID=$(id -u "$SUDO_USER")
    fi

    local SERVICE_FILE="$TARGET_HOME/.config/systemd/user/audiot-kiosk.service"
    local AUTOSTART_DIR="$TARGET_HOME/.config/autostart"

    # Wrapper to run commands as the target user with the correct D-Bus environment
    run_as_user() {
        if [ "$EUID" -eq 0 ]; then
            sudo -u "$TARGET_USER" env XDG_RUNTIME_DIR="/run/user/$TARGET_UID" DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$TARGET_UID/bus" bash -c "$1"
        else
            bash -c "$1"
        fi
    }

    if run_as_user "command -v systemctl >/dev/null 2>&1 && systemctl --user >/dev/null 2>&1"; then
        info "Setting up systemd user service for kiosk..."
        run_as_user "mkdir -p \"$(dirname "$SERVICE_FILE")\""
        
        cat > /tmp/audiot-kiosk.service << EOF
[Unit]
Description=AUDiot Dashboard Kiosk
After=graphical-session.target network-online.target
Wants=graphical-session.target
[Service]
Type=simple
Environment=DISPLAY=:0
Environment=XAUTHORITY=%h/.Xauthority
ExecStart=$KIOSK_SCRIPT
Restart=always
RestartSec=10
[Install]
WantedBy=graphical-session.target
EOF
        mv /tmp/audiot-kiosk.service "$SERVICE_FILE"
        chown "$TARGET_USER:$TARGET_USER" "$SERVICE_FILE"
        
        run_as_user "systemctl --user daemon-reload"
        run_as_user "systemctl --user enable --now audiot-kiosk.service 2>/dev/null || true"
        info "Kiosk service enabled and started."
    else
        warn "systemd user service not available. Kiosk will not autostart via systemd."
        info "Setting up XDG autostart as fallback..."
        run_as_user "mkdir -p \"$AUTOSTART_DIR\""
        
        cat > /tmp/audiot-kiosk.desktop << EOF
[Desktop Entry]
Type=Application
Name=AUDiot Kiosk
Comment=Launch AUDiot Grafana dashboard in kiosk mode
Exec=$KIOSK_SCRIPT
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
EOF
        mv /tmp/audiot-kiosk.desktop "$AUTOSTART_DIR/audiot-kiosk.desktop"
        chown "$TARGET_USER:$TARGET_USER" "$AUTOSTART_DIR/audiot-kiosk.desktop"
        info "XDG autostart entry created. The kiosk will start on the next desktop login."
    fi
}

# Updates the script itself to the latest version.
do_self_update() {
    info "Checking for updates to the 'audiot-dashboard' command..."
    local temp_script
    temp_script=$(mktemp)
    
    # Add a timestamp to the URL to bypass GitHub's raw file cache (usually 5 mins)
    local cache_buster="?v=$(date +%s)"
    
    if fetch_from_repo "${SELF_URL}${cache_buster}" "$temp_script"; then
        local local_hash=""
        local remote_hash=""
        
        # Calculate hashes to see if they are different
        if [ -f "$SCRIPT_PATH_ON_HOST" ]; then
            local_hash=$(sha256sum "$SCRIPT_PATH_ON_HOST" | cut -d' ' -f1)
        elif [ -f "$0" ]; then
            local_hash=$(sha256sum "$0" | cut -d' ' -f1)
        fi
        remote_hash=$(sha256sum "$temp_script" | cut -d' ' -f1)
        
        if [[ "$local_hash" == "$remote_hash" ]]; then
            info "'audiot-dashboard' is already at the latest version."
            rm -f "$temp_script"
            return
        fi

        info "Installing new version of 'audiot-dashboard'..."
        sudo mv "$temp_script" "$SCRIPT_PATH_ON_HOST"
        sudo chmod +x "$SCRIPT_PATH_ON_HOST"
        info "'audiot-dashboard' has been updated. Please re-run your command."
        exit 0
    else
        die "Failed to download the latest version of the script."
    fi
}

# Shows the Grafana container logs.
do_show_logs() {
    info "Showing Grafana logs..."
    docker compose -f "$INSTALL_DIR/docker-compose.yml" logs --tail=100 -f grafana
}

# Shows the status of the Docker services.
do_show_status() {
    info "Docker services status:"
    docker compose -f "$INSTALL_DIR/docker-compose.yml" ps
    echo ""
    if systemctl --user is-active audiot-kiosk.service >/dev/null 2>&1; then
        info "Kiosk service status:"
        systemctl --user status audiot-kiosk.service --no-pager
    fi
}

# --- Main Command Handler ---
main() {
    case "${1:-}" in
        install)
            do_install_or_update "false"
            ;;
        update)
            do_self_update
            do_install_or_update "true"
            ;;
        set)
            [ -z "${2:-}" ] && die "Usage: audiot-dashboard set <dashboard-uid>"
            do_set_dashboard "$2"
            ;;
        restart)
            info "Restarting services..."
            docker compose -f "$INSTALL_DIR/docker-compose.yml" restart
            do_restart_kiosk
            ;;
        logs)
            do_show_logs
            ;;
        status)
            do_show_status
            ;;
        *)
            cat <<'EOF'
AUDiot Dashboard Manager v2.0

A single script to rule them all.

Usage:
  audiot-dashboard <command>

Commands:
  install      Performs a fresh installation of the dashboard stack and kiosk.
  update       Checks for updates to the script and stack configurations.
  set <uid>    Sets the active dashboard for the kiosk and restarts it.
  restart      Restarts the Grafana and kiosk services.
  status       Shows the status of the running services.
  logs         Tails the Grafana container logs.

Installation:
  curl -fsSL https://raw.githubusercontent.com/Audumla/AUDiotMonitor/main/monitoring/dashboard/audiot-dashboard | sudo bash -s install

EOF
            exit 1
            ;;
    esac
}

main "$@"
