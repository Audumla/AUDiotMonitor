[Unit]
Description=AUDiot Dashboard Kiosk
After=network.target graphical-session.target
Wants=graphical-session.target
StartLimitIntervalSec=0

[Service]
Type=simple
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/dietpi/.Xauthority
# Point to the host-owned layout install path
WorkingDirectory=/opt/docker/services/dashboard
ExecStart=/opt/docker/services/dashboard/kiosk.sh
Restart=always
RestartSec=10
User=dietpi

[Install]
WantedBy=graphical-session.target
