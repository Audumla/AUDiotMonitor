{
  "uid": "audiot-triple-gpu-wide",
  "title": "AUDiot Triple GPU Wide",
  "tags": ["audiot", "custom", "wide", "gpu"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "GPU 1 Compute",
      "description": "Navi 31 - pci-0000:03:00.0",
      "gridPos": { "h": 9, "w": 3, "x": 0, "y": 0 },
      "targets": [{
        "expr": "hw_device_utilization_percent{device_class=\"gpu\", component=\"compute\", device_id=\"pci-0000:03:00.0\"}",
        "legendFormat": "GPU 1"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "GPU 2 Compute",
