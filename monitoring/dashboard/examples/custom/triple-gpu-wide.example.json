    {
      "id": 8,
      "type": "gauge",
      "title": "RAM",
      "description": "System memory utilization",
      "gridPos": { "h": 9, "w": 3, "x": 21, "y": 0 },
      "targets": [{
        "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
        "legendFormat": "RAM"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
