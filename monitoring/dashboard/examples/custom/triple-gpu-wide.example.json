{
  "uid": "audiot-triple-gpu-wide",
  "title": "AUDiot Triple GPU Wide",
  "tags": ["audiot", "custom", "wide", "gpu"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": "GPU-Compute-1",
      "type": "gauge",
      "title": "${__series.name} Compute",
      "gridPos": { "h": 5, "w": 3, "x": 0, "y": 0 },
      "targets": [{
        "expr": "hw_device_utilization_percent{component=\"compute\", device_id=\"pci-0000:03:00.0\"} * on(device_id) group_left(model) hw_device_info",
        "legendFormat": "{{model}}"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": "GPU-RAM-1",
      "type": "gauge",
      "title": "${__series.name} VRAM",
      "gridPos": { "h": 6, "w": 3, "x": 0, "y": 5 },
      "targets": [{
        "expr": "(sum by(device_id) (hw_device_capacity_bytes{device_id=\"pci-0000:03:00.0\", sensor=\"usage\"}) / sum by(device_id) (hw_device_capacity_bytes{device_id=\"pci-0000:03:00.0\", sensor=\"capacity\"}) * 100) * on(device_id) group_left(model) hw_device_info",
        "legendFormat": "{{model}}"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "noValue": "N/A"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
