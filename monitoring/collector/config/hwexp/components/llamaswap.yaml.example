# llamaswap component manifest EXAMPLE
#
# Reference manifest for monitoring a local llama-swap instance.
# Demonstrates the gateway_manifest adapter schema (spec-801).
#
# Once the gateway_manifest adapter is implemented (Stage 1.2),
# copy this file (without the .example suffix) to /etc/hwexp/components/
# on the collector host.

id: llamaswap
display_name: "llama-swap"
enabled: true

connection:
  host: "127.0.0.1"
  port: 41080
  auth:
    type: none

health:
  endpoint: /health
  expect_status: 200
  timeout_s: 3

metrics:
  - id: models_loaded
    endpoint: /v1/models
    extract: ".data | length"
    prometheus_name: gateway_llamaswap_models_loaded
    unit: count
    poll_interval_s: 15

  - id: active_model
    endpoint: /v1/models
    extract: '.data[0].id // "none"'
    prometheus_name: gateway_llamaswap_active_model
    unit: label
    poll_interval_s: 15

  - id: vram_ratio
    endpoint: /metrics
    extract: "llama_kv_cache_usage_ratio"
    prometheus_name: gateway_llamaswap_vram_ratio
    unit: ratio
    poll_interval_s: 30
    source_format: prometheus
