# Ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LLAMASWAP_EXPORTER_PORT=9300

# Llama-swap endpoint
# When llama-swap is on the same host, use the container name: http://llamaswap:8080
# When remote, use the host IP: http://10.10.100.10:41080
LLAMASWAP_URL=http://llamaswap:8080
LLAMASWAP_POLL_INTERVAL=15

# Grafana
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS=true
GRAFANA_ANON_ROLE=Viewer

# Prometheus retention
PROMETHEUS_RETENTION=30d
