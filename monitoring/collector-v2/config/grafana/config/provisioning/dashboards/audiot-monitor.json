{
    "id": null,
    "uid": "audiot-monitor-001",
    "title": "AUDiot Monitor - GPU/CPU/Memory/Llama",
    "tags": [
        "netdata",
        "llamaswap",
        "monitoring"
    ],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 2,
    "refresh": "10s",
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "panels": [
        {
            "id": 1,
            "type": "row",
            "title": "GPU - 3x AMD Radeon RX 7900 XTX",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "collapsed": false
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "GPU Utilization (%)",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 1
            },
            "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
            },
            "targets": [
                {
                    "expr": "label_replace(netdata_amdgpu_gpu_utilization_percentage_average{dimension=\"utilization\", chart=~\".*card1.*\"}, \"gpu_label\", \"R9700\", \"chart\", \".*\")\n  or\nlabel_replace(netdata_amdgpu_gpu_utilization_percentage_average{dimension=\"utilization\", chart=~\".*card0.*\"}, \"gpu_label\", \"7900-XTX 1\", \"chart\", \".*\")\n  or\nlabel_replace(netdata_amdgpu_gpu_utilization_percentage_average{dimension=\"utilization\", chart=~\".*card2.*\"}, \"gpu_label\", \"7900-XTX 2\", \"chart\", \".*\")",
                    "legendFormat": "{{gpu_label}}"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 70
                            },
                            {
                                "color": "red",
                                "value": 90
                            }
                        ]
                    }
                }
            }
        },
        {
            "id": 3,
            "type": "timeseries",
            "title": "VRAM Usage (%)",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 1
            },
            "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
            },
            "targets": [
                {
                    "expr": "label_replace(netdata_amdgpu_gpu_mem_vram_usage_perc_percentage_average{chart=~\".*card1.*\"}, \"gpu_label\", \"R9700\", \"chart\", \".*\")\n  or\nlabel_replace(netdata_amdgpu_gpu_mem_vram_usage_perc_percentage_average{chart=~\".*card0.*\"}, \"gpu_label\", \"7900-XTX 1\", \"chart\", \".*\")\n  or\nlabel_replace(netdata_amdgpu_gpu_mem_vram_usage_perc_percentage_average{chart=~\".*card2.*\"}, \"gpu_label\", \"7900-XTX 2\", \"chart\", \".*\")",
                    "legendFormat": "{{gpu_label}} VRAM%"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 70
                            },
                            {
                                "color": "red",
                                "value": 90
                            }
                        ]
                    }
                }
            }
        },
        {
