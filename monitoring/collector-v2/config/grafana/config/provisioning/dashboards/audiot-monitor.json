                    "expr": "label_replace(netdata_amdgpu_gpu_mem_vram_usage_bytes_average{dimension=~\"used|free\", chart=~\".*card1.*\"} / 1024 / 1024, \"gpu_label\", \"R9700\", \"chart\", \".*\")\n  or\nlabel_replace(netdata_amdgpu_gpu_mem_vram_usage_bytes_average{dimension=~\"used|free\", chart=~\".*card0.*\"} / 1024 / 1024, \"gpu_label\", \"7900-XTX 1\", \"chart\", \".*\")\n  or\nlabel_replace(netdata_amdgpu_gpu_mem_vram_usage_bytes_average{dimension=~\"used|free\", chart=~\".*card2.*\"} / 1024 / 1024, \"gpu_label\", \"7900-XTX 2\", \"chart\", \".*\")",
