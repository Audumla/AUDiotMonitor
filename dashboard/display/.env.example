# URL of the Prometheus instance running in the server stack.
# Change this to the IP/hostname of the machine running dashboard/server/.
PROMETHEUS_URL=http://192.168.1.10:9090

# Grafana admin password (default: admin — change this in production).
GF_ADMIN_PASSWORD=admin

# Anonymous read-only access — set to false to require login for every user.
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
